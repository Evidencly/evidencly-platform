# Evidencly Platform — Environment Variables
# Copy this file to .env and fill in your API keys
# Never commit .env to version control

# -----------------------------------------------
# Database
# -----------------------------------------------
DATABASE_URL=postgresql://evidencly_user:yourpassword@localhost:5432/evidencly
POSTGRES_DB=evidencly
POSTGRES_USER=evidencly_user
POSTGRES_PASSWORD=yourpassword

# -----------------------------------------------
# Chain Data APIs
# -----------------------------------------------

# Etherscan V2 — https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key

# BscScan — https://bscscan.com/apis (Phase 2)
BSCSCAN_API_KEY=your_bscscan_api_key

# TronGrid — https://www.trongrid.io (Phase 2)
TRONGRID_API_KEY=your_trongrid_api_key

# Helius (Solana) — https://helius.dev (Phase 2)
HELIUS_API_KEY=your_helius_api_key

# Blockstream (Bitcoin) — no key required for public endpoints (Phase 2)
# BLOCKSTREAM_API_URL=https://blockstream.info/api

# -----------------------------------------------
# AI Layer
# -----------------------------------------------

# DeepSeek — https://platform.deepseek.com
# Default AI brain for entity classification and narrative generation
# Swappable for any OpenAI-compatible API
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_URL=https://api.deepseek.com/v1

# Optional: swap to OpenAI, Anthropic, or local Ollama
# OPENAI_API_KEY=your_openai_api_key
# ANTHROPIC_API_KEY=your_anthropic_api_key
# OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------
# Web and Social Search
# -----------------------------------------------

# Brave Search API — https://api.search.brave.com
BRAVE_SEARCH_API_KEY=your_brave_search_api_key

# Twitter/X Bearer Token — https://developer.twitter.com
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# -----------------------------------------------
# Application
# -----------------------------------------------

# Admin token for protected endpoints (generate a strong random string)
ADMIN_TOKEN=generate_a_strong_random_string_here

# Environment: development or production
ENVIRONMENT=production

# Backend port
PORT=8004

# CORS origins (comma-separated, use * for development only)
CORS_ORIGINS=https://evidencly.com

# -----------------------------------------------
# Optional: AIS Stream (Phase 2 — future)
# -----------------------------------------------
# AISSTREAM_API_KEY=your_aisstream_api_key

# -----------------------------------------------
# Notes
# -----------------------------------------------
# Minimum required to run:
#   DATABASE_URL
#   ETHERSCAN_API_KEY
#   DEEPSEEK_API_KEY
#   ADMIN_TOKEN
#
# Everything else enables additional data sources
# The platform degrades gracefully if optional keys are missing
